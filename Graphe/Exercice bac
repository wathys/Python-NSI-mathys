def est_balade(t):
    for i in t:
        if not sont_voisine(i):
            return False
    return True

def trajet(tab):
    s=0
    for i in range(len(tab)+1):
        s+=tab[1].duree
        for j in tab[1].voisine:
            if j[0] == tab[i+1]:
                s += j[1]
    s+=tab[len(tab)].duree
    return s

def parcours(attr, deja_vues, balade,nb):
    if not attr.nom in deja_vues:
        deja_vues[attr.nom] = True
        if nb == 0 or sont_voisine(attr,balade[nb-1]):
            balade[nb] = attr
            nb = nb + 1
        for voisine in attr.voisine:
            nb = parcours(voisine[0],deja_vues,balade,nb)
    return nb

